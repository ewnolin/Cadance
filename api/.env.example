# Copy to .env and fill in real values. NEVER commit .env.

# development | production | test
NODE_ENV=development

# Port the API listens on
PORT=4000

# Secret used to sign session cookies. MUST be long and random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Path to the SQLite database file. Defaults to ./data/cadance.db when unset.
# In Docker, point this at a mounted named volume so data survives restarts.
DATABASE_PATH=./data/cadance.db

# Comma-separated list of allowed CORS origins (the Expo app).
# e.g. http://localhost:8081,https://cadance.example.com
CORS_ORIGIN=http://localhost:8081
